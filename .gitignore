# eBPF compiled artifacts (generated by make)
sentinel-core/backend/ebpf-lib/compiled/
sentinel-core/backend/ebpf-lib/programs/**/*.o
sentinel-core/backend/ebpf-lib/vmlinux.h
sentinel-core/backend/ebpf_lib

# Runtime hyphen→underscore symlink created by backend/conftest.py
sentinel-core/backend/firewall_adapters

# IDE
.vscode/
.idea/
.cursor/
# Allow specific .cursor files that are useful to share
!.cursor/rules/
!.cursor/rules/**
!.cursor/skills/
!.cursor/skills/**
!.cursor/BUGBOT.md
!.cursor/mcp.json
!.cursor/MCP.md
*.swp
*.swo
*~

# Cursor debug/temp logs
.cursor/debug*.log
.cursor/*.log

# OS
.DS_Store
Thumbs.db
desktop.ini

# Environment
.env
.env.local
.env.*.local
sentinelenv
sentinel_env

# Testing / Coverage
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.tox/

# Build artifacts
*.log
*.pid

# Training datasets (large files)
sentinel-core/training/datasets/data/cicids2018/
sentinel-core/training/datasets/data/cicids2017/
sentinel-core/training/datasets/data/unsw_nb15/
sentinel-core/training/datasets/data/MANIFEST.txt

# Preprocessed dataset cache (regenerated from raw data by data_loader.py;
# cicids2018_full.npz alone is ~900 MB)
sentinel-core/training/datasets/cache/

# Trained model weights (large binary files)
sentinel-core/backend/ai-engine/trained_models/

# TypeScript incremental build info — regenerated on every `tsc` run
*.tsbuildinfo

# External reference PDFs kept locally (system cards, analyst reports, etc.)
# Scoped to repo root so genuine PDFs under sentinel-core/docs/ can still be tracked.
/*.pdf

# AWS keys and local CLI install (never commit)
*.pem
.sentinel-instance-id
.sentinel-instance-ip
sentinel-core/training/aws/
sentinel-core/training/awscliv2.zip

# Specification documents (sensitive, distributed out-of-band)
sentinel-core/docs/specifications/

# Claude Code — personal project memory (optional; see CLAUDE.md)
CLAUDE.local.md

# Cursor sync
.cursor-sync/chat-history-backup/
.cursor-sync/sync-config.json
# Note: .cursor-sync/agent-transcripts/ is versioned (intentional)
sentinel-core/backend/.test-venv/

# Caveman compress backups
*.original.md

# Claude Code — user-local settings + skill-manager experiments
# (settings.local.json is per-machine; .agents/ and skills-lock.json belong to
# an experimental skill manager separate from gstack — not committed yet).
.claude/
.agents/
skills-lock.json
.gstack/
