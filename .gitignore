# Dependencies
node_modules/
.pnp.*
.yarn/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl
venv/
.venv/
.venv-backend/
dragon_scale_env/

# eBPF compiled artifacts (generated by make)
dragon-scale-core/backend/ebpf-lib/compiled/
dragon-scale-core/backend/ebpf-lib/programs/**/*.o
dragon-scale-core/backend/ebpf-lib/vmlinux.h
dragon-scale-core/backend/ebpf_lib

# Runtime hyphen→underscore symlink created by backend/conftest.py
dragon-scale-core/backend/firewall_adapters

# IDE
.vscode/
.idea/
.cursor/
# Allow specific .cursor files that are useful to share
!.cursor/rules/
!.cursor/rules/**
!.cursor/skills/
!.cursor/skills/**
!.cursor/BUGBOT.md
!.cursor/mcp.json
!.cursor/MCP.md
*.swp
*.swo
*~

# Cursor debug/temp logs
.cursor/debug*.log
.cursor/*.log

# OS
.DS_Store
Thumbs.db
desktop.ini

# Environment
.env
.env.local
.env.*.local
dragonscaleenv
dragon_scale_env

# Testing / Coverage
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.tox/

# Build artifacts
*.log
*.pid

# Training datasets (large files)
dragon-scale-core/training/datasets/data/cicids2018/
dragon-scale-core/training/datasets/data/cicids2017/
dragon-scale-core/training/datasets/data/unsw_nb15/
dragon-scale-core/training/datasets/data/MANIFEST.txt

# Preprocessed dataset cache (regenerated from raw data by data_loader.py;
# cicids2018_full.npz alone is ~900 MB)
dragon-scale-core/training/datasets/cache/

# Trained model weights (large binary files)
dragon-scale-core/backend/ai-engine/trained_models/

# TypeScript incremental build info — regenerated on every `tsc` run
*.tsbuildinfo

# External reference PDFs kept locally (system cards, analyst reports, etc.)
# Scoped to repo root so genuine PDFs under dragon-scale-core/docs/ can still be tracked.
/*.pdf

# AWS keys and local CLI install (never commit)
*.pem
.dragon-scale-instance-id
.dragon-scale-instance-ip
dragon-scale-core/training/aws/
dragon-scale-core/training/awscliv2.zip

# Specification documents (sensitive, distributed out-of-band)
dragon-scale-core/docs/specifications/

# Claude Code — personal project memory (optional; see CLAUDE.md)
CLAUDE.local.md

# Cursor sync
.cursor-sync/chat-history-backup/
.cursor-sync/sync-config.json
# Note: .cursor-sync/agent-transcripts/ is versioned (intentional)
dragon-scale-core/backend/.test-venv/
