FROM python:3.11-slim
LABEL maintainer="SENTINEL Team"
LABEL description="SENTINEL stream job — statistical anomaly detection"

RUN apt-get update && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd -r sentinel && useradd -r -g sentinel -d /app -s /sbin/nologin sentinel

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip setuptools wheel \
    && pip install --no-cache-dir -r requirements.txt

COPY base_job.py anomaly_detection.py ./

RUN chown -R sentinel:sentinel /app
USER sentinel

ENV PYTHONUNBUFFERED=1

ENTRYPOINT ["python", "anomaly_detection.py"]
