# SENTINEL Platform Configuration
# Copy to .env and update values for your environment

# === Security (REQUIRED — change in production) ===
JWT_SECRET_KEY=replace-with-64-random-characters
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-admin-password
ADMIN_EMAIL=admin@yourdomain.com

# === Database ===
# Two distinct PostgreSQL roles:
#   - sentinel       (migration user) — table owner, superuser/BYPASSRLS.
#                    Used only by db-migrate to run Alembic.
#   - sentinel_app   (runtime user)   — NOSUPERUSER NOBYPASSRLS, scoped grants,
#                    INSERT/SELECT on audit_log only. Used by all app services
#                    at request time. Created by migration 20260417_003;
#                    granted LOGIN + password by migration 20260524_001 from
#                    SENTINEL_APP_DB_PASSWORD below.
POSTGRES_DB=sentinel_db
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=replace-with-strong-postgres-password
SENTINEL_APP_DB_PASSWORD=replace-with-strong-sentinel-app-password

# === Tenancy (single-tenant defaults) ===
# DEFAULT_TENANT_ID is the fallback tenant for DB queries that run before
# the JWT has been parsed (e.g. /auth/login lookup). Single-tenant deploys
# set this to the operator's tenant id (typically 1). Multi-tenant deploys
# leave it unset and supply a tenant hint in the login payload.
# BOOTSTRAP_TENANT_ID is the tenant_id assigned to the initial admin row
# created by auth-service on first boot. Keep aligned with DEFAULT_TENANT_ID
# so the pre-auth lookup can find the admin.
DEFAULT_TENANT_ID=1
BOOTSTRAP_TENANT_ID=1

# === Notifications ===
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=security@yourdomain.com

# === Grafana ===
GRAFANA_PASSWORD=replace-with-strong-grafana-password

# === Internal Service Token ===
INTERNAL_SERVICE_TOKEN=replace-with-64-random-characters

# === API Gateway CORS ===
# Comma-separated browser origins allowed to call the gateway.
# Required when SENTINEL_ENV=production (the gateway refuses to start otherwise).
CORS_ORIGINS=http://localhost:3000

# === Observability — Phase 0 slice 5 (OTel pilot) ===
# Empty = telemetry disabled. api-gateway emits OTLP-gRPC traces + metrics
# when set. Local dev: bring up Tempo via `docker compose --profile
# observability up -d tempo`, then set:
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
OTEL_EXPORTER_OTLP_ENDPOINT=

# XDP profile only; required when running `docker compose --profile xdp up xdp-collector`.
# XDP_KAFKA_BOOTSTRAP_SERVERS=
# XDP_AUTH_SERVICE_URL=
