# SENTINEL Platform Configuration
# Copy to .env and update values for your environment

# === Security (REQUIRED — change in production) ===
JWT_SECRET_KEY=replace-with-64-random-characters
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-admin-password
ADMIN_EMAIL=admin@yourdomain.com

# === Database ===
POSTGRES_DB=sentinel_db
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=replace-with-strong-postgres-password

# === Notifications ===
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=security@yourdomain.com

# === Grafana ===
GRAFANA_PASSWORD=replace-with-strong-grafana-password

# === Internal Service Token ===
INTERNAL_SERVICE_TOKEN=replace-with-64-random-characters

# === Observability — Phase 0 slice 5 (OTel pilot) ===
# Empty = telemetry disabled. api-gateway emits OTLP-gRPC traces + metrics
# when set. Local dev: bring up Tempo via `docker compose --profile
# observability up -d tempo`, then set:
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
OTEL_EXPORTER_OTLP_ENDPOINT=

# XDP profile only; required when running `docker compose --profile xdp up xdp-collector`.
# XDP_KAFKA_BOOTSTRAP_SERVERS=
# XDP_AUTH_SERVICE_URL=
