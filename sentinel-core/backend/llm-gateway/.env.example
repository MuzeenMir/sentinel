# --- LLM Gateway (analyst copilot) configuration ---

# Anthropic inference. When unset, the gateway serves /health but /copilot/*
# returns 503 (inference disabled). NEVER commit a real key.
ANTHROPIC_API_KEY=

# Internal service auth (forwarded to upstream services as X-Internal-Service-Token).
INTERNAL_SERVICE_TOKEN=

# Upstream services the copilot reads from (grounding tools).
AI_ENGINE_URL=http://ai-engine:5003
API_GATEWAY_URL=http://api-gateway:8080
POLICY_SERVICE_URL=http://policy-orchestrator:5004

# State + limits.
REDIS_URL=redis://localhost:6379
COPILOT_SESSION_TTL=3600
COPILOT_MAX_TOTAL_TOKENS=100000
COPILOT_RATE_LIMIT=20

# Service port.
PORT=5012
