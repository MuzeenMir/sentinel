{
  "mcpServers": {
    "sentinel": {
      "command": "sentinel-core/backend/.venv-backend/bin/python",
      "args": [
        "sentinel-core/mcp-servers/sentinel/server.py"
      ],
      "env": {
        "SENTINEL_API_URL": "http://localhost:8080",
        "SENTINEL_API_TOKEN": ""
      }
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": ""
      }
    },
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://sentinel:sentinel_password@localhost:5433/sentinel_db"
      ]
    },
    "redis": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-redis",
        "redis://localhost:6379"
      ]
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/mir/sentinel"
      ]
    }
  }
}
